<%- include('partials/header')%>

<section class="store-section">
    <div class="store-info">
        <h1>Welcome to Sneaker Store</h1>
        <p>Your one-stop shop for the latest and greatest sneakers. Explore our collection and find your perfect pair today!</p>
    </div>
</section>

<section class="featured-sneakers">
    <h2>Featured Sneakers</h2>
    <div class="sneaker-grid">
        <% sneakers.forEach(sneaker => { %>
            <a href="/product/<%= sneaker.id %>" class="sneaker-card">
                <div class="sneaker-image">
                    <img src="/<%= sneaker.image_url %>" alt="Sneaker <%= sneaker.id %>">
                </div>
            </a>
        <% }); %>
    </div>
</section>

<%- include('partials/footer')%>